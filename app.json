{
  "expo": {
    "name": "LicitAcesso",
    "slug": "licitacesso",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "licitacesso",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.licitacesso.app"
    },
    
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#003d9b"
      },
      "package": "br.com.licitacesso.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.386479303029-o797r5u4nt3ikqss0jcltf8upmkhqsfs"
        }
      ],
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "splash": {
      "backgroundColor": "#003d9b",
      "image": "./assets/images/splash-icon.png", 
      "resizeMode": "contain"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "59d3d8b6-3fb8-4101-9d07-3c59847ccefb"
      }
    },
    "owner": "teste1235"
  }
}
